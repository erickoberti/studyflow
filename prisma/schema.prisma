generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(cuid())
  name               String
  email              String               @unique
  passwordHash       String
  activeStudyGuideId String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  studyGuides        StudyGuide[]         @relation("StudyGuideOwner")
  activeStudyGuide   StudyGuide?          @relation("ActiveStudyGuide", fields: [activeStudyGuideId], references: [id], onDelete: SetNull)
  disciplines        Discipline[]
  subjects           Subject[]
  cycleEntries       CycleEntry[]
  sessions           StudySession[]
  settings           UserSettings?
  guideSettings      StudyGuideSettings[]
  resetTokens        PasswordResetToken[]
}

model StudyGuide {
  id          String         @id @default(cuid())
  userId      String
  name        String
  icon        String         @default("book-open")
  color       String         @default("#6366f1")
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation("StudyGuideOwner", fields: [userId], references: [id], onDelete: Cascade)
  activeUsers User[]         @relation("ActiveStudyGuide")
  disciplines   Discipline[]
  subjects      Subject[]
  cycleEntries  CycleEntry[]
  sessions      StudySession[]
  settings      StudyGuideSettings?

  @@unique([userId, name])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Discipline {
  id        String      @id @default(cuid())
  userId    String
  studyGuideId String?
  name      String
  sortOrder Int?
  category  String?
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyGuide StudyGuide? @relation(fields: [studyGuideId], references: [id], onDelete: Cascade)
  subjects  Subject[]

  @@unique([userId, studyGuideId, name])
  @@index([userId])
  @@index([studyGuideId])
}

model Subject {
  id            String       @id @default(cuid())
  userId        String
  studyGuideId  String?
  disciplineId  String
  name          String
  weight        Int          @default(1)
  notes         String?
  tecReference  String?
  groupName     String?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyGuide    StudyGuide?  @relation(fields: [studyGuideId], references: [id], onDelete: Cascade)
  discipline    Discipline   @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  cycleEntries  CycleEntry[]

  @@index([userId])
  @@index([studyGuideId])
  @@index([disciplineId])
  @@unique([userId, studyGuideId, disciplineId, name])
}

model CycleEntry {
  id         String         @id @default(cuid())
  userId     String
  studyGuideId String?
  subjectId  String
  orderIndex Int
  active     Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyGuide StudyGuide?    @relation(fields: [studyGuideId], references: [id], onDelete: Cascade)
  subject    Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sessions   StudySession[]

  @@index([userId])
  @@index([studyGuideId])
  @@index([subjectId])
  @@unique([userId, studyGuideId, orderIndex])
}

model StudySession {
  id           String    @id @default(cuid())
  userId       String
  studyGuideId String?
  cycleEntryId String
  date         DateTime
  questions    Int
  correct      Int
  wrong        Int
  percentage   Float
  estimatedMinutes Int @default(0)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyGuide   StudyGuide? @relation(fields: [studyGuideId], references: [id], onDelete: Cascade)
  cycleEntry   CycleEntry @relation(fields: [cycleEntryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([studyGuideId])
  @@index([date])
  @@index([cycleEntryId])
}

model UserSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  targetPercentage    Float    @default(80)
  dailyQuestionsGoal  Int      @default(30)
  weeklyQuestionsGoal Int      @default(200)
  weightPriorityBias  Float    @default(1.25)
  theme               String   @default("system")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyGuideSettings {
  id                  String     @id @default(cuid())
  userId              String
  studyGuideId        String     @unique
  targetPercentage    Float      @default(80)
  dailyQuestionsGoal  Int        @default(30)
  weeklyQuestionsGoal Int        @default(200)
  weightPriorityBias  Float      @default(1.25)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyGuide          StudyGuide @relation(fields: [studyGuideId], references: [id], onDelete: Cascade)

  @@unique([userId, studyGuideId])
  @@index([userId])
}

model GoalDefinition {
  id          String   @id
  code        String   @unique
  title       String
  description String?
  metric      String
  targetValue Int
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([metric, active])
}


